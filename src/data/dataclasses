from datetime import datetime
import pickle
from dataclasses import fields, field, dataclass
from typing import Type, TypeVar, List, Any, Optional, Union, Dict

T = TypeVar('T', bound='BaseTable')

class BaseTable:
    def to_pickle(self, filename: str):
        with open(filename, 'wb') as f:
            pickle.dump(self, f)

    @classmethod
    def from_pickle(cls: Type[T], filename: str) -> T:
        with open(filename, 'rb') as f:
            return pickle.load(f)

    def _get_column_names(self) -> List[str]:
        """Returns all list field names defined in the dataclass."""
        return [f.name for f in fields(self)]

    def find_records(self, column_name: str, value: Union[int, str]) -> List[int]:
        """
        Searches a column and returns a list of matching row indices.
        - If value is int: exact match.
        - If value is str: starts with (case-insensitive).
        """
        if not hasattr(self, column_name):
            print(f"Column '{column_name}' does not exist.")
            return []

        column_data = getattr(self, column_name)
        ids = getattr(self, self._get_column_names()[0])
        id_column = dict(zip(ids, column_data))
        matching_indices = []

        for i, item in id_column.items():
            if isinstance(value, int):
                if item == value:
                    matching_indices.append(i)
            elif isinstance(value, str):
                # Using .lower() for a more user-friendly case-insensitive search
                if str(item).lower().startswith(value.lower()):
                    matching_indices.append(i)
        
        return matching_indices

    def find_index_by_id(self, target_id: int) -> Optional[int]:
        """Helper to find the row index for a given ID."""
        try:
            # Assumes every table has an 'ids' or 'client_ids' etc. 
            # We'll standardize the primary ID column as the first field.
            id_list = getattr(self, self._get_column_names()[0])
            return id_list.index(target_id)
        except (ValueError, IndexError):
            return None

    def delete_record(self, target_ids: Union[int, List[int]]) -> List[Dict[str, Any]]:
        """Removes the row associated with the ID from all lists."""
        if isinstance(target_ids, int):
            id_list = [target_ids]
        else:
            id_list = target_ids
        print(id_list)
        for tid in id_list:    
            if tid is not None:
                row_id = self.find_index_by_id(tid)
                for col in self._get_column_names():
                    getattr(self, col).pop(row_id)
                print(f"Record {tid} deleted.")
            else:
                print(f"ID {tid} not found.")

    def update_record(self, target_id: int, **kwargs):
        """Updates specific fields for a record. Usage: table.update_record(1, names='New Name')"""
        idx = self.find_index_by_id(target_id)
        if idx is not None:
            for key, value in kwargs.items():
                if hasattr(self, key):
                    getattr(self, key)[idx] = value
            print(f"Record {target_id} updated.")
        else:
            print(f"ID {target_id} not found.")

    def display_records(self, target_ids: Union[int, List[int]]) -> List[Dict[str, Any]]:
            """
            Takes a single ID or a list of IDs.
            Returns a list of dictionaries containing the record data.
            Prints the data for quick debugging.
            """
            # Ensure list, allows for multiple inputs
            if isinstance(target_ids, int):
                id_list = [target_ids]
            else:
                id_list = target_ids

            results = []
            columns = self._get_column_names()

            # Find each ID record and add to results
            for tid in id_list:
                idx = self.find_index_by_id(tid)
                
                if idx is not None:
                    # Build the record dictionary
                    record_data = {col: getattr(self, col)[idx] for col in columns}
                    results.append(record_data)
                    
                else:
                    print(f"Record ID {tid} not found.")

            return results

@dataclass
class ClientTable(BaseTable):
    ids: List[int] = field(default_factory=list)
    record_types: List[str] = field(default_factory=list)
    names: List[str] = field(default_factory=list)
    address_line_1s: List[str] = field(default_factory=list)
    address_line_2s: List[str] = field(default_factory=list)
    address_line_3s: List[str] = field(default_factory=list)
    cities: List[str] = field(default_factory=list)
    states: List[str] = field(default_factory=list)
    zip_codes: List[str] = field(default_factory=list)
    countries: List[str] = field(default_factory=list)
    phone_numbers: List[str] = field(default_factory=list)

    def append_row(
            self, 
            name: str, 
            addr1: str, 
            addr2: str, 
            addr3: str, 
            city: str, 
            state: str, 
            zip_code: str, 
            country: str, 
            phone: str,
            record_type: str = "ClientTable" 
        ):
            """Adds a complete client record to the columnar lists."""
            try:
                id = self.ids[-1]
            except IndexError:
                id = 0
            
            self.ids.append(int(id + 1))
            self.record_types.append(str(record_type))
            self.names.append(str(name))
            self.address_line_1s.append(str(addr1))
            self.address_line_2s.append(str(addr2))
            self.address_line_3s.append(str(addr3))
            self.cities.append(str(city))
            self.states.append(str(state))
            self.zip_codes.append(str(zip_code))
            self.countries.append(str(country))
            self.phone_numbers.append(str(phone))

@dataclass
class AirlineTable(BaseTable):
    ids: List[int] = field(default_factory=list)
    record_types: List[str] = field(default_factory=list)
    company_names: List[str] = field(default_factory=list)

    def append_row(self, id: int, record_type: str, company_name: str):
        """Adds a new airline record to the table."""
        try:
            id = self.ids[-1]
        except IndexError:
            id = 0
            
        self.ids.append(int(id + 1))
        self.record_types.append(str(record_type))
        self.company_names.append(str(company_name))


@dataclass
class FlightTable(BaseTable):
    ids: List[int] = field(default_factory=list) 
    airline_ids: List[int] = field(default_factory=list)
    dates: List[datetime] = field(default_factory=list)
    start_cities: List[str] = field(default_factory=list)
    end_cities: List[str] = field(default_factory=list)

    date_format = "%Y/%m/%d %H:%M:%S"   

    def append_row(self, client_id: int, airline_id: int, date: datetime, start: str, end: str):
        """Adds a new flight record to the table."""
        try:
            id = self.ids[-1]
        except IndexError:
            id = 0
            
        self.ids.append(int(id + 1))
        self.airline_ids.append(int(airline_id))
        self.dates.append(datetime.strptime(str(date), self.date_format))
        self.start_cities.append(str(start))
        self.end_cities.append(str(end))


